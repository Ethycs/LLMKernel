{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "default": "1.0.0",
      "type": "string"
    },
    "blockers": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "display_id": {
      "type": "string"
    },
    "percent": {
      "maximum": 100,
      "minimum": 0,
      "type": "number"
    },
    "status": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "status"
  ],
  "type": "object"
}
