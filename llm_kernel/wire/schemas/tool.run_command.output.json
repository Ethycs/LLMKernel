{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "type": "string"
    },
    "duration_ms": {
      "minimum": 0,
      "type": "integer"
    },
    "exit_code": {
      "type": "integer"
    },
    "run_id": {
      "format": "uuid",
      "type": "string"
    },
    "stderr": {
      "type": "string"
    },
    "stdout": {
      "type": "string"
    },
    "timed_out": {
      "type": "boolean"
    }
  },
  "required": [
    "exit_code",
    "stdout",
    "stderr",
    "run_id"
  ],
  "type": "object"
}
