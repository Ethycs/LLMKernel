{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "answered_at": {
      "format": "date-time",
      "type": "string"
    },
    "run_id": {
      "format": "uuid",
      "type": "string"
    }
  },
  "required": [
    "answer",
    "run_id"
  ],
  "type": "object"
}
