{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "default": "1.0.0",
      "type": "string"
    },
    "action": {
      "minLength": 1,
      "type": "string"
    },
    "preview": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "body": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "text",
            "diff",
            "plan",
            "code",
            "json"
          ],
          "type": "string"
        }
      },
      "required": [],
      "type": "object"
    },
    "rationale": {
      "minLength": 1,
      "type": "string"
    },
    "scope": {
      "default": "one_shot",
      "enum": [
        "one_shot",
        "this_file",
        "this_zone",
        "session"
      ],
      "type": "string"
    },
    "timeout_ms": {
      "default": 1800000,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "action",
    "rationale"
  ],
  "type": "object"
}
