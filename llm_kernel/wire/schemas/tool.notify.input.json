{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "default": "1.0.0",
      "type": "string"
    },
    "importance": {
      "enum": [
        "trace",
        "info",
        "warn"
      ],
      "type": "string"
    },
    "observation": {
      "minLength": 1,
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "observation",
    "importance"
  ],
  "type": "object"
}
