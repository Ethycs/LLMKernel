{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "default": "1.0.0",
      "type": "string"
    },
    "encoding": {
      "default": "utf-8",
      "enum": [
        "utf-8",
        "base64"
      ],
      "type": "string"
    },
    "max_bytes": {
      "default": 1048576,
      "minimum": 1,
      "type": "integer"
    },
    "path": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "path"
  ],
  "type": "object"
}
