{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "default": "1.0.0",
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "reason": {
      "minLength": 1,
      "type": "string"
    },
    "severity": {
      "enum": [
        "medium",
        "high",
        "critical"
      ],
      "type": "string"
    },
    "timeout_ms": {
      "default": 300000,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "reason",
    "severity"
  ],
  "type": "object"
}
