{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "default": "1.0.0",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
          "kind": {
            "enum": [
              "file",
              "diff",
              "plan",
              "url",
              "log"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          }
        },
        "required": [
          "uri",
          "kind"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "outcome": {
      "default": "success",
      "enum": [
        "success",
        "partial",
        "aborted"
      ],
      "type": "string"
    },
    "summary": {
      "minLength": 1,
      "type": "string"
    },
    "task_id": {
      "type": "string"
    }
  },
  "required": [
    "summary"
  ],
  "type": "object"
}
