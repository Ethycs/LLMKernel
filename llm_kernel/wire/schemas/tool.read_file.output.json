{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "_rfc_version": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "encoding": {
      "enum": [
        "utf-8",
        "base64"
      ],
      "type": "string"
    },
    "run_id": {
      "format": "uuid",
      "type": "string"
    },
    "size_bytes": {
      "minimum": 0,
      "type": "integer"
    },
    "truncated": {
      "type": "boolean"
    }
  },
  "required": [
    "content",
    "encoding",
    "run_id"
  ],
  "type": "object"
}
