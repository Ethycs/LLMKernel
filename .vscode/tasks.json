{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "compile",
            "path": "vscode-llm-kernel-extension",
            "group": "build",
            "label": "npm: compile - vscode-llm-kernel-extension",
            "presentation": {
                "panel": "dedicated",
                "reveal": "never"
            },
            "problemMatcher": "$tsc"
        },
        {
            "type": "npm",
            "script": "watch",
            "path": "vscode-llm-kernel-extension",
            "isBackground": true,
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "label": "npm: watch - vscode-llm-kernel-extension",
            "presentation": {
                "panel": "dedicated",
                "reveal": "never"
            },
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
                            "file": 1,
                            "location": 2,
                            "severity": 3,
                            "code": 4,
                            "message": 5
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^\\s*\\d{1,2}:\\d{1,2}:\\d{1,2}(?: AM| PM)? - File change detected\\. Starting incremental compilation\\.\\.\\.",
                        "endsPattern": "^\\s*\\d{1,2}:\\d{1,2}:\\d{1,2}(?: AM| PM)? - (?:Found \\d+ errors?\\. Watching for file changes\\.|Compilation complete\\. Watching for file changes\\.)"
                    }
                }
            ]
        },
        {
            "label": "npm: install extension deps",
            "type": "shell",
            "command": "npm install",
            "options": {
                "cwd": "${workspaceFolder}/vscode-llm-kernel-extension"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
